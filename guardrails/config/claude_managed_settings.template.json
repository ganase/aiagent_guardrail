{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(powershell -enc *)",
      "Bash(powershell -encodedcommand *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git tag *)",
      "Bash(npm publish *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"%AIAGENT_GUARDRAIL_HOME%\\hooks\\run_guardrail_hook.cmd\""
          }
        ]
      }
    ]
  },
  "allowedMcpServers": [],
  "allowManagedMcpServersOnly": true,
  "allowManagedHooksOnly": true,
  "allowManagedPermissionRulesOnly": true,
  "allowedHttpHookUrls": []
}
